# Copia a .env.local y completa con tu proyecto Supabase.
# Sin estas variables el dashboard corre en modo DEMO (datos simulados).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Dispositivo que mira el Overview (uuid). Por defecto: UNIDAD-01 del seed.
NEXT_PUBLIC_DEVICE_ID=00000000-0000-0000-0000-000000000001
