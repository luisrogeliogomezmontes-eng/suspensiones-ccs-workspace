// Supabase — usar la PUBLISHABLE key (rol anon). La SECRET/service_role JAMÁS.
#define SUPABASE_URL        "https://xxxx.supabase.co"
#define SUPABASE_ANON_KEY   "sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx"

// Token propio del device (header x-device-token) para consumir comandos.
// Debe existir en la tabla device_tokens de Supabase (I3.2).
#define DEVICE_TOKEN        "dvt_xxxxxxxxxxxxxxxxxxxxxxxx"
